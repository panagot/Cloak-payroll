# --- Solana cluster (see README: devnet / testnet) ---
# mainnet-beta | devnet | testnet
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# JSON-RPC (optional). Default is a public Ankr pool — good for Vercel without an API key.
# If you set this to https://api.mainnet-beta.solana.com (or devnet/testnet Solana Foundation hosts),
# browser traffic can get 403 and the app will show a warning bar.
# For production / heavy use, set a mainnet provider URL, e.g.:
# NEXT_PUBLIC_SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# NEXT_PUBLIC_SOLANA_RPC=https://YOUR-ENDPOINT.solana-mainnet.quiknode.pro/YOUR_TOKEN/

# Optional: override USDC mint (defaults: mainnet EPjF…, devnet Circle test USDC)
# Required if NEXT_PUBLIC_SOLANA_NETWORK=testnet
# NEXT_PUBLIC_USDC_MINT=

# Optional: Cloak relay base URL.
# In the browser, the app defaults to same-origin /api/cloak-relay (proxies to https://api.cloak.ag) to avoid CORS on localhost.
# Set this only to override (e.g. absolute URL to your deployed proxy, or a different relay host).
# NEXT_PUBLIC_CLOAK_RELAY_URL=

# Optional: public GitHub URL for the “Source” link in the footer
# NEXT_PUBLIC_GITHUB_REPO=https://github.com/your-org/cloak-shielded-payroll
